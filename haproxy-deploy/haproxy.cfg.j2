global
    log /dev/log local0
    log /dev/log local1 notice
    daemon

defaults
    log global
    mode tcp
    option tcplog
    timeout connect 5s
    timeout client 50s
    timeout server 50s

frontend kubernetes-api
    bind *:6443
    mode tcp
    default_backend kubernetes-apiservers

# Frontend para tráfego HTTP (porta 80)
frontend http-in
    bind *:80
    mode tcp
    default_backend traefik-http

# Backend para HTTP - distribui entre os 3 masters na porta 30080
backend traefik-http
    mode tcp
    balance roundrobin
    option tcplog
    server master1 10.10.50.30:30080 check fall 3 rise 2
    server master2 10.10.50.31:30080 check fall 3 rise 2
    server master3 10.10.50.32:30080 check fall 3 rise 2

# Frontend para tráfego HTTPS (porta 443)
frontend https-in
    bind *:443
    mode tcp
    default_backend traefik-https

# Backend para HTTPS - distribui entre os 3 masters na porta 30443
backend traefik-https
    mode tcp
    balance roundrobin
    option tcplog
    server master1 10.10.50.30:30443 check fall 3 rise 2
    server master2 10.10.50.31:30443 check fall 3 rise 2
    server master3 10.10.50.32:30443 check fall 3 rise 2

backend kubernetes-apiservers
    mode tcp
    balance roundrobin
    # Sem httpchk – usa TCP check apenas
    {% for cp in control_planes %}
    server cp{{ loop.index }} {{ cp.ip }}:6443 check fall 3 rise 2
    {% endfor %}

frontend stats
    bind *:8404
    mode http
    stats enable
    stats uri /haproxy?stats
    stats refresh 10s
    stats auth {{ haproxy_stats_user }}:{{ haproxy_stats_pass }}

